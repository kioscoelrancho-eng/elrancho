<!-- ── CONCEITO ── -->
<section id="conceito">
  <div class="container">
    <div class="conceito-header reveal">
      <div class="section-eyebrow" style="justify-content:center;">O Conceito</div>
      <h2 class="section-title" style="text-align:center;margin-top:14px;">
        Finger food que dispensa talheres<br /><em>e impressiona.</em>
      </h2>
    </div>
  </div>

  <div class="conceito-grid">
    <div class="conceito-card reveal">
      <img
        src="data:image/svg+xml;base64,"
        alt="Pizza artesanal no forno de pedra com chamas"
        loading="lazy"
      />
      <div class="conceito-caption">
        <h3>Forno Artesanal</h3>
        <p>Alta temperatura, borda dourada e crocante. Cada pizza sai do forno pronta para encantar.</p>
      </div>
    </div>
    <div class="conceito-card reveal">
      <img
        src="data:image/svg+xml;base64,"
        alt="Pizza artesanal sobre tábua de madeira rústica"
        loading="lazy"
      />
